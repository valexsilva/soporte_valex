# ---- Aplicacion ----
APP_NAME=soporte-valex
ENVIRONMENT=dev

# ---- Enrutamiento LLM (Punto 2) ----
LLM_PRIMARY=devin
LLM_FALLBACK=local
LOCAL_LLM_ENDPOINT=http://localhost:8000/v1
# Devin es un agente autonomo de larga duracion: cuando es el proveedor se
# despacha de forma ASINCRONA (estado waiting_devin) y la sesion se reanuda
# vIa POST /api/devin/callback. Poner en false para el modo sincrono (polling).
DEVIN_ASYNC=true

# ---- Bucle ReAct (Punto 5) ----
REACT_MAX_CYCLES=3
REACT_CONFIDENCE_THRESHOLD=0.9

# ---- Integraciones (Punto 1) ----
# Salida hacia Teams: 'webhook' (Incoming Webhook / Power Automate) | 'simulated'.
TEAMS_MODE=webhook
SERVICENOW_MODE=simulated

# ---- ServiceNow (creación de folios / incidentes) ----
# En modo 'simulated' (o sin INSTANCE_URL) se genera un folio INC... ficticio.
# Para creación real: SERVICENOW_MODE=webhook + credenciales de la instancia.
SERVICENOW_INSTANCE_URL=
# api_user/api_token = usuario+contraseña (basic) o usuario+contraseña del
# usuario (oauth password grant).
SERVICENOW_API_USER=
SERVICENOW_API_TOKEN=
# Autenticación: 'basic' u 'oauth'.
SERVICENOW_AUTH=basic
# OAuth (System OAuth > Application Registry > Endpoint for external clients):
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=
# Opcional; por defecto {INSTANCE_URL}/oauth_token.do
SERVICENOW_OAUTH_TOKEN_URL=
SERVICENOW_TIMEOUT_SECONDS=15
# Método de folio:
#  - 'guidance': NO crea el folio; devuelve los pasos para que el usuario lo
#    levante en el Catálogo Técnico (usar mientras no haya API key/credenciales).
#  - 'incident': POST a la tabla incident.
#  - 'catalog' : Service Catalog order_now (forma real en Santander -> REQ).
SERVICENOW_FOLIO_METHOD=guidance
SERVICENOW_TABLE=incident
SERVICENOW_DEFAULT_CATEGORY=infrastructure
SERVICENOW_DEFAULT_ASSIGNMENT_GROUP=Area-X
# --- Service Catalog (si FOLIO_METHOD=catalog) ---
# sys_id del catalog item (p. ej. 'Middleware Services').
SERVICENOW_CATALOG_ITEM_SYSID=
SERVICENOW_CATALOG_QUANTITY=1
# Variables fijas del item (sys_ids propios de la instancia). JSON una línea:
# SERVICENOW_CATALOG_VARIABLES={"requested_for":"<sysid>","company_requester":"<sysid>","product_service":"<sysid>","type_of_request":"<sysid>","email":"buzon@santander.com.mx","phone":"55..."}
SERVICENOW_CATALOG_VARIABLES={}
# Variable del item donde volcar la descripción del diagnóstico (si existe).
SERVICENOW_CATALOG_DESCRIPTION_VARIABLE=

# ---- OpenShift (diagnóstico vía CLI 'oc') ----
# 'simulated' devuelve datos ficticios; 'cli' ejecuta 'oc' contra el clúster.
# NOTA: en 'pro' NO se usa OpenShift (regla: pro = solo Dynatrace) -> denied.
OPENSHIFT_MODE=simulated
# Ruta al binario 'oc' (o nombre si está en el PATH).
OPENSHIFT_OC_PATH=oc
# Opcional: kubeconfig a usar (si vacío, usa el login/contexto actual de 'oc').
OPENSHIFT_KUBECONFIG=
# Un CONTEXTO de 'oc' = un clúster. El namespace se pasa con --namespace (los
# contextos dan acceso a varios proyectos). Un entorno puede tener varios
# clústeres (mx1/mx2): se consultan todos y se agregan.
# Prerrequisito: 'oc login' a cada clúster (luego 'oc config rename-context').
#   Contextos creados: dev-str01-mx1, pre-mex02-mx1, pre-mex02-mx2,
#                      pre-ocp04-mx1, pre-ocp04-mx2 (apigateway)
#   (pro queda fuera por la regla 'pro = solo Dynatrace')
#
# Contextos (clústeres) por entorno. JSON una línea:
# OPENSHIFT_ENV_CONTEXTS={"dev":["dev-str01-mx1"],"pre":["pre-mex02-mx1","pre-mex02-mx2"]}
OPENSHIFT_ENV_CONTEXTS={}
# Plantilla de namespace de respaldo (patrón mx-<comp>-<env> en estos clústeres).
OPENSHIFT_NAMESPACE_TEMPLATE=mx-{component}-{environment}
# Override por componente -> entorno -> {contexts?, namespace?, deployment?}.
# 'contexts' reemplaza ENV_CONTEXTS (apigateway vive en ocp04). JSON una línea:
# OPENSHIFT_COMPONENT_MAP={"apigateway":{"pre":{"contexts":["pre-ocp04-mx1","pre-ocp04-mx2"],"namespace":"mx-api-gateway-pre"}}}
OPENSHIFT_COMPONENT_MAP={}
OPENSHIFT_TAIL_LINES=100
OPENSHIFT_TIMEOUT_SECONDS=20

# ---- Devin API ----
DEVIN_API_BASE=https://api.devin.ai/v3
DEVIN_ORG_ID=
DEVIN_API_KEY=
DEVIN_TIMEOUT_SECONDS=30
DEVIN_POLL_INTERVAL_SECONDS=3
DEVIN_POLL_MAX_ATTEMPTS=40

# ---- Teams Webhooks (entrada/salida con Adaptive Cards) ----
# Usar con TEAMS_MODE=webhook. No requiere Azure/Entra ni bot.
# SALIDA: URL del Incoming Webhook del canal (o flujo de Workflows).
TEAMS_WEBHOOK_INCOMING_URL=
# ENTRADA: token HMAC que Teams genera al crear el Outgoing Webhook.
TEAMS_WEBHOOK_SECURITY_TOKEN=
TEAMS_WEBHOOK_TIMEOUT_SECONDS=10
# ANTI-BUCLE: palabra clave que dispara el flujo de Power Automate (ENTRADA).
# Se neutraliza (carácter invisible) en TODA salida del agente para que sus
# respuestas no se reenvíen a sí mismas. Debe coincidir con la del flujo.
TEAMS_WEBHOOK_LOOP_GUARD_KEYWORD=SoporteGD
# Intervalo (s) del poller que reanuda sesiones Devin y publica la respuesta.
TEAMS_WEBHOOK_POLLER_INTERVAL_SECONDS=20

# ---- ENTRADA por Outlook de escritorio (COM/MAPI) ----
# El listener (scripts/run_outlook_listener.py) lee las notificaciones de Teams
# desde el Outlook YA autenticado en la máquina (Windows). No requiere IMAP ni
# credenciales. Publica la respuesta por el Incoming Webhook.
TEAMS_EMAIL_SENDER_FILTER=teams.microsoft.com
# Si usas un flujo de Power Automate que reenvía el canal al correo, filtra
# por asunto (tiene prioridad sobre el remitente). Ej: "Soporte GD".
TEAMS_EMAIL_SUBJECT_FILTER=
TEAMS_EMAIL_POLL_INTERVAL_SECONDS=30
# Prefijo de disparo: solo se procesan mensajes que empiezan con este prefijo
# (evita ecos del propio bot y chatter). Se elimina antes de pasarlo al agente.
# Vacío = sin filtro. Recuérdale al usuario anteponerlo a sus mensajes.
TEAMS_EMAIL_TRIGGER_PREFIX=SoporteGD

# ---- Estado y Auditoria (Puntos 3/4) ----
STATE_BACKEND=redis
AUDIT_BACKEND=kafka

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_STATE_TTL_SECONDS=3600
# RESP protocol: 3 (Redis >=6) o 2 (servidores antiguos sin soporte HELLO)
REDIS_PROTOCOL=3

# Kafka (auditoria)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_AUDIT_TOPIC=agent-audit-logs
# Seguridad: PLAINTEXT | SSL | SASL_PLAINTEXT | SASL_SSL
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# SASL: PLAIN | SCRAM-SHA-256 | SCRAM-SHA-512 | GSSAPI (Kerberos)
KAFKA_SASL_MECHANISM=
KAFKA_SASL_PLAIN_USERNAME=
KAFKA_SASL_PLAIN_PASSWORD=
# Kerberos (GSSAPI): nombre del servicio del broker
KAFKA_SASL_KERBEROS_SERVICE_NAME=
# TLS: CA en formato PEM (convertir desde truststore JKS con keytool+openssl)
KAFKA_SSL_CAFILE=
KAFKA_SSL_CHECK_HOSTNAME=true
KAFKA_ACKS=all
KAFKA_RETRIES=5
KAFKA_REQUEST_TIMEOUT_MS=15000

# NOTA Kerberos: requiere ticket valido via krb5.conf + keytab/principal
# (variable de entorno KRB5_CONFIG y kinit), y el paquete 'gssapi'
# (Linux) o 'winkerberos' (Windows). Solo viable en el entorno de
# despliegue Linux donde existen keytab/truststore.

# ---- Oracle (Puntos 4/6) ----
ORACLE_ENABLED=false
ORACLE_DSN=
ORACLE_USER=
ORACLE_PASSWORD=
